{
  "manifest_version": 3,
  "name": "__MSG_ext_name__",
  "version": "1.6.2",
  "description": "__MSG_ext_desc__",
  "default_locale": "en",
  "homepage_url": "https://buymeacoffee.com/romanzbudowy",
  "permissions": ["activeTab", "scripting", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "__MSG_action_title__"
  },
  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+A"
      },
      "description": "__MSG_action_title__"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
